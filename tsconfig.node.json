{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "dist-electron",
    "rootDir": "electron",
    "composite": true,
    "strict": true,
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["electron"],
  "exclude": ["electron/**/*.test.ts", "electron/**/*.test.js"]
}
